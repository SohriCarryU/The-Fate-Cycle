# OpenAI API Settings
# Sensitive values such as API keys stay in backend/.env.
# Non-sensitive runtime overrides can be stored in game_data/config/runtime_config.json.
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-3.5-turbo"
OPENAI_MODEL_CHEAT_CHECK="qwen3-235b-a22b"

# Image Generation Settings (optional - leave empty to disable)
# IMAGE_GEN_MODEL="gpt-image-1"  # 图片生成模型
# IMAGE_GEN_BASE_URL=""  # 为空则使用 OPENAI_BASE_URL
# IMAGE_GEN_API_KEY=""  # 为空则使用 OPENAI_API_KEY
# IMAGE_GEN_IDLE_SECONDS=10  # 状态静止多少秒后触发图片生成

# JWT Settings for OAuth2
SECRET_KEY="a_very_secret_key_that_should_be_changed"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Linux.do OAuth Settings
LINUXDO_CLIENT_ID="your_linuxdo_client_id"
LINUXDO_CLIENT_SECRET="your_linuxdo_client_secret"
LINUXDO_SCOPE="read"

# Simple Login Settings (for friend playtests)
# For LAN playtests, set HOST="0.0.0.0" below and share only your LAN URL
# plus this temporary invite code with friends. Players enter a display name
# and the invite code; admin access is optional and should stay with the host.
# Do not share backend/.env, real API keys, database files, or admin passwords.
SIMPLE_LOGIN_INVITE_CODE="your_invite_code_here"
SIMPLE_LOGIN_ALLOW_EMPTY_INVITE=false

# Admin Settings (leave empty or unset to disable admin login)
ADMIN_PASSWORD="your_admin_password_here"
ADMIN_SESSION_COOKIE="admin_token"
ADMIN_SESSION_EXPIRE_MINUTES=120

# --- Database ---
# The connection string for your SQLite database.
#
# For a Linux or macOS absolute path, use FOUR slashes:
# Example: DATABASE_URL="sqlite:////path/to/your/veloera.db"
#
# For a Windows absolute path, use THREE slashes:
# Example: DATABASE_URL="sqlite:///C:/path/to/your/veloera.db"
#
# The default value below points to a file in the project's root directory.
DATABASE_URL="sqlite:///veloera.db"

# --- Server Settings ---
HOST="127.0.0.1"
PORT=8000
UVICORN_RELOAD=true
